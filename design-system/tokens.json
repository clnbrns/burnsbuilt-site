{
  "$schema": "https://schemas.brand-tokens.dev/v1",
  "brand": "BurnsBuilt",
  "version": "1.0.0",
  "color": {
    "primary": {
      "navy": {
        "value": "#142640",
        "description": "Harbor Navy — anchor. Backgrounds, primary buttons, Father block."
      },
      "tan": {
        "value": "#D9B382",
        "description": "Workshop Tan — softer warm tone."
      },
      "tan-2": {
        "value": "#C49A62",
        "description": "Workshop Tan — primary highlight, Son block."
      },
      "tan-soft": {
        "value": "#EAD9BE",
        "description": "Soft Tan — washes, badges."
      },
      "cream": {
        "value": "#F5ECE0",
        "description": "Paper Cream — reverse-out, large surfaces."
      },
      "paper": {
        "value": "#FBF7F0",
        "description": "Paper — default page background."
      }
    },
    "support": {
      "navy-deep": {
        "value": "#0D1A2D"
      },
      "navy-2": {
        "value": "#1E3A5F"
      },
      "steel": {
        "value": "#3D5A80"
      },
      "tan-3": {
        "value": "#B88850"
      },
      "ink": {
        "value": "#0E1A2E"
      },
      "bone": {
        "value": "#F0EEE9"
      }
    },
    "functional": {
      "rule": {
        "value": "rgba(20,38,64,0.12)"
      },
      "success": {
        "value": "#2E8C5D"
      },
      "warn": {
        "value": "#B8462E"
      }
    }
  },
  "typography": {
    "family": {
      "display": {
        "value": "Archivo, system-ui, sans-serif",
        "weights": [
          400,
          700,
          800,
          900
        ]
      },
      "body": {
        "value": "Inter, system-ui, sans-serif",
        "weights": [
          400,
          500,
          600,
          700
        ]
      },
      "mono": {
        "value": "JetBrains Mono, ui-monospace, monospace",
        "weights": [
          400,
          500,
          600
        ]
      }
    },
    "scale": {
      "display": {
        "size": "84px",
        "line-height": "88px",
        "tracking": "-0.025em",
        "family": "display",
        "weight": 800
      },
      "h1": {
        "size": "56px",
        "line-height": "60px",
        "tracking": "-0.022em",
        "family": "display",
        "weight": 800
      },
      "h2": {
        "size": "36px",
        "line-height": "42px",
        "tracking": "-0.02em",
        "family": "display",
        "weight": 800
      },
      "h3": {
        "size": "24px",
        "line-height": "30px",
        "tracking": "-0.015em",
        "family": "display",
        "weight": 800
      },
      "body-l": {
        "size": "18px",
        "line-height": "27px",
        "tracking": "0",
        "family": "body",
        "weight": 400
      },
      "body": {
        "size": "15px",
        "line-height": "23px",
        "tracking": "0",
        "family": "body",
        "weight": 400
      },
      "caption": {
        "size": "12px",
        "line-height": "1.4",
        "tracking": "0.18em",
        "family": "mono",
        "weight": 500,
        "transform": "uppercase"
      },
      "stamp": {
        "size": "10px",
        "line-height": "1.4",
        "tracking": "0.22em",
        "family": "mono",
        "weight": 500,
        "transform": "uppercase"
      }
    }
  },
  "radius": {
    "sm": {
      "value": "4px",
      "use": "badges, label chips"
    },
    "md": {
      "value": "6px",
      "use": "buttons, inputs"
    },
    "lg": {
      "value": "10px",
      "use": "ui cards"
    },
    "xl": {
      "value": "12px",
      "use": "surface panels"
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "56px",
    "16": "80px"
  }
}